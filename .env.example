# Prisma / PostgreSQL
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cms_multitenant?schema=public"
DATABASE_URL_UNPOOLED="postgresql://postgres:postgres@localhost:5432/cms_multitenant?schema=public"

# App runtime
APP_ENV="development"
DEFAULT_SITE_DOMAIN="alpha.localhost:3000"

# Admin authentication
SESSION_COOKIE_NAME="cms_admin_session"
SESSION_SECRET="replace-with-a-long-random-secret-at-least-32-characters"

# Notes
# - Next.js va Vercel tu cung cap NODE_ENV o runtime, khong can khai bao them.
# - DATABASE_URL nen la pooled URL cho app runtime.
# - DATABASE_URL_UNPOOLED nen la unpooled/direct connection URL cho Prisma migrate.
# - Tren Vercel, set cac bien moi truong ben tren cho Preview/Production theo nhu cau.
